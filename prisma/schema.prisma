generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model Admin {
  id           Int      @id @default(autoincrement())
  username     String   @unique
  passwordHash String
  createdAt    DateTime @default(now())
}

model Berita {
  id        Int      @id @default(autoincrement())
  kategori  String   // majelis | saitun | mamre | moria | permata | seraya | umum
  sektor    Int?     // null = bp/runggun, 1-8 = sektor tertentu
  judul     String
  ringkasan String?
  isi       String   @db.Text
  penulis   String
  lokasi    String?
  jam       String?
  imgUrl    String?
  tanggal   DateTime
  createdAt DateTime @default(now())
}

model Renungan {
  id        Int      @id @default(autoincrement())
  tanggal   DateTime
  ayat      String
  judul     String
  isi       String   @db.Text
  penulis   String
  imgUrl    String?
  createdAt DateTime @default(now())
}

model Video {
  id         Int      @id @default(autoincrement())
  judul      String
  youtubeUrl String
  tanggal    DateTime
  kategori   String
  createdAt  DateTime @default(now())
}

model Momo {
  id              Int      @id @default(autoincrement())
  tanggal         DateTime
  sesi            String   // pagi | sore
  judul           String
  pengkhotbah     String?
  ayatNas         String?
  persembahanPujian String?
  fileUrl         String?
  fileName        String?
  createdAt       DateTime @default(now())
}

model Keuangan {
  id         Int      @id @default(autoincrement())
  tanggal    DateTime
  tipe       String   // masuk | keluar
  keterangan String
  jumlah     Float
  kategori   String
  catatan    String?
  buktiFoto  String?
  createdAt  DateTime @default(now())
}

model Jadwal {
  id         Int      @id @default(autoincrement())
  tanggal    DateTime
  judul      String
  deskripsi  String?
  warna      String   @default("#B91C1C")
  createdAt  DateTime @default(now())
}

model AnggotaOrg {
  id       Int     @id @default(autoincrement())
  kategori String  // majelis | saitun | mamre | moria | permata | seraya
  level    String  // gereja | klasis | sektor
  sektor   Int?
  jabatan  String
  nama     String
  noWa     String?
  urutan   Int     @default(0)
  createdAt DateTime @default(now())
}

model SiteConfig {
  id           Int    @id @default(1)
  pagiMulai    String @default("08.00")
  pagiSelesai  String @default("10.30")
  pagiBahasa   String @default("Bahasa Karo / Indonesia")
  soreMulai    String @default("18.00")
  soreSelesai  String @default("19.30")
  soreBahasa   String @default("Bahasa Indonesia")
  malamMulai   String @default("18.00")
  malamSelesai String @default("19.30")
  alamat       String @default("GJVF+3R3, Jl. Tanjung Sari, Kel. Sempakata, Kec. Medan Selayang, Kota Medan 20133")
  telepon      String @default("")
  whatsapp     String @default("")
  email        String @default("gbkp.tanjungsari@gmail.com")
  mapsUrl      String @default("https://www.google.com/maps/place/GBKP+Tanjung+Sari/@3.5426388,98.6245348,19z")
  mapsEmbed    String @default("https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d497.8!2d98.6245348!3d3.5426388!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x30312f87a64539d7%3A0xcb68077110b05047!2sGBKP%20Tanjung%20Sari!5e0!3m2!1sid!2sid!4v1710800000000!5m2!1sid!2sid")
  logoUrl      String @default("/logo-gbkp.png")
}
