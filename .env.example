# Copy file ini menjadi .env dan isi dengan nilai yang sesuai

# Database PostgreSQL
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/gbkp"

# JWT Secret - gunakan string acak yang panjang
JWT_SECRET="ganti_dengan_secret_panjang_dan_acak_minimal_32_karakter"

# Admin credentials (untuk seed)
ADMIN_USERNAME="admin"
ADMIN_PASSWORD="password_anda"
